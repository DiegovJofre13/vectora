# Postgres (Supabase u otro) — Project Settings → Database → Connection string ("URI", conexión directa).
DATABASE_URL="postgresql://usuario:password@host:5432/postgres"
PORT=4310
VECTORA_PROBE_DEMO_PORT=4500

# Key de OpenAI de Vectora (no del cliente) para el gateway de modelos. Sin esto,
# probe.completar() falla con un error claro; el resto de Vectora funciona igual.
OPENAI_API_KEY=
